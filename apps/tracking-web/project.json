{
  "name": "tracking-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/tracking-web/src",
  "tags": [
    "scope:tracking",
    "type:app"
  ],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/tracking-web",
        "index": "apps/tracking-web/src/index.html",
        "browser": "apps/tracking-web/src/main.ts",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/tracking-web/tsconfig.app.json",
        "assets": [
          "apps/tracking-web/src/favicon.ico",
          "apps/tracking-web/src/assets"
        ],
        "styles": [
          "apps/tracking-web/src/styles.css"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "tracking-web:build:production"
        },
        "development": {
          "buildTarget": "tracking-web:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "port": 4300,
        "proxyConfig": "proxy.conf.json"
      },
      "continuous": true
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "apps/tracking-web/**/*.ts",
          "apps/tracking-web/**/*.html"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/tracking-web/jest.config.ts",
        "tsConfig": "apps/tracking-web/tsconfig.spec.json"
      }
    }
  }
}
