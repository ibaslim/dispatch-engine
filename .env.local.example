# Database
DATABASE_URL=postgresql+asyncpg://dispatch:dispatch@localhost:5432/dispatch_dev
DATABASE_TEST_URL=postgresql+asyncpg://dispatch:dispatch@localhost:5432/dispatch_test

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=changeme-generate-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application URLs
DISPATCHER_WEB_BASE_URL=http://localhost:4200
TRACKING_WEB_BASE_URL=http://localhost:4300
API_BASE_URL=http://localhost:8000

# Mail (Mailpit for local/stage)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@dispatch.local
MAIL_STARTTLS=false
MAIL_SSL=false

# Platform admin bootstrap (used by CLI)
PLATFORM_ADMIN_EMAIL=admin@dispatch.local

# Firebase (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Feature flags
FEATURE_MULTI_STORE=true
